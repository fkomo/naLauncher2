<Window x:Class="naLauncher2.Wpf.RestoreDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Height"
        Width="320"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="ButtonStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3F42"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BackupItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D3133"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3A3F42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="#FF282C2E" BorderBrush="#FF404448" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Restore Library" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="24,20,24,16"
                       Cursor="SizeAll" MouseLeftButtonDown="Border_MouseLeftButtonDown"/>
            <TextBlock x:Name="EmptyText" Text="No backup files found." Foreground="White" Opacity="0.5"
                       FontSize="13" Margin="24,0,24,16" Visibility="Collapsed"/>
            <ScrollViewer x:Name="BackupScroll" MaxHeight="280" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                <ListBox x:Name="BackupList" Background="Transparent" BorderThickness="0"
                         ItemContainerStyle="{StaticResource BackupItemStyle}"
                         SelectionChanged="BackupList_SelectionChanged"
                         MouseDoubleClick="BackupList_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding DisplayDate}" Foreground="White" FontSize="13"/>
                                <TextBlock Grid.Column="1" Text="{Binding DisplaySize}" Foreground="White" Opacity="0.5"
                                           FontSize="12" Margin="16,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
            <Rectangle Height="1" Fill="#FF404448"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="RestoreButton" Style="{StaticResource ButtonStyle}" Text="Restore"
                           Foreground="LightSkyBlue" MouseLeftButtonUp="Restore_Click" Visibility="Collapsed"/>
                <TextBlock Style="{StaticResource ButtonStyle}" Text="Cancel" MouseLeftButtonUp="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
